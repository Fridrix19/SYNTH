# PostgreSQL (Neon, Vercel Postgres, Supabase, и т.д.)
# Пример Neon: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Обратная связь (Gmail: включите 2FA → пароль приложения)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your@gmail.com"
SMTP_PASS="app-password-16-chars"
# Куда слать письма (по умолчанию на сервере уже fedorhavalic@gmail.com)
# CONTACT_TO_EMAIL="fedorhavalic@gmail.com"
