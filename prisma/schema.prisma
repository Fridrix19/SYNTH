generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Component {
  id        String  @id
  sourceKey String  @map("source_key")
  name      String
  price     Int
  image     String?
  socket    String?
  hot       Boolean @default(false)
  isAmd     Boolean @default(false) @map("is_amd")

  @@index([sourceKey])
  @@map("components")
}

model ReadyBuild {
  id        String  @id
  name      String
  specs     String
  price     Int
  image     String?
  cpu       String
  gpu       String
  ram       String
  storage   String
  cooling   String
  badge     String?
  sortOrder Int     @default(0) @map("sort_order")
  homeOrder Int?    @map("home_order")

  @@map("ready_builds")
}
